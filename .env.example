# ============================================
# Antick Async — Environment Variables (root)
# ============================================
# Copy file ini ke .env lalu isi nilai sebenarnya.
# JANGAN commit file .env ke repository!
# File ini dibaca docker-compose (env_file auth-service & cloudflared,
# serta variable substitution ${...} di docker-compose.yml).

# ---- GENERAL ----
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- DATABASE (auth-db & item-db) ----
# Dipakai untuk POSTGRES_PASSWORD kedua DB + DATABASE_URL kedua service.
# Jika dikosongkan, default dev "postgres123" yang dipakai.
# ⚠️ Mengganti nilai ini tidak mengubah password volume DB yang sudah ter-init.
POSTGRES_PASSWORD=postgres123

# ---- JWT / AUTH ----
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- CORS (auth-service, comma-separated) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://antick-async.online

# ---- INITIAL SUPERADMIN (wajib ganti password saat login pertama) ----
SUPERADMIN_EMAIL=superadmin@admin.com
SUPERADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_BUKAN_NILAI_ASLI

# ---- SMTP EMAIL (Hostinger) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=no-reply@salut-utsamarinda.com
SMTP_PASSWORD=tulis-password-email-disini
MAIL_FROM=no-reply@salut-utsamarinda.com
MAIL_FROM_NAME=Antick Async IT Support

# ---- CLOUDFLARE TUNNEL (RAHASIA — hanya di .env produksi) ----
TUNNEL_TOKEN=PASTE_TOKEN_PANJANG_CLOUDFLARE_KAMU_DISINI
