# Auth Service Environment Template
# Copy to .env and fill in production values

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@auth-db:5432/auth_db
SECRET_KEY=YOUR_SECURE_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPERADMIN_PASSWORD=YOUR_STRONG_SUPERADMIN_PASSWORD
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
